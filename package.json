{
  "name": "awesome-lowcode",
  "version": "1.0.0",
  "description": "企业级低代码开发平台",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src lowcode --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint src lowcode --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,css,scss,json}\" \"lowcode/**/*.{js,jsx,ts,tsx,css,scss,json}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,css,scss,json}\" \"lowcode/**/*.{js,jsx,ts,tsx,css,scss,json}\"",
    "test": "vitest",
    "test:coverage": "vitest --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gafieldKan/awesome-lowcode.git"
  },
  "keywords": [
    "lowcode",
    "react",
    "vite",
    "antd"
  ],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/gafieldKan/awesome-lowcode/issues"
  },
  "homepage": "https://github.com/gafieldKan/awesome-lowcode#readme",
  "dependencies": {
    "@ant-design/icons": "^6.1.1",
    "@vitejs/plugin-react": "^6.0.1",
    "antd": "^6.3.6",
    "commander": "^14.0.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.1",
    "vite": "^8.0.8",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^16.0.0",
    "jsdom": "^26.0.0",
    "prettier": "^3.8.3",
    "vitest": "^3.0.0"
  }
}
